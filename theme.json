{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"slug": "base",
					"color": "#ffffff",
					"name": "پس‌زمینه"
				},
				{
					"slug": "surface",
					"color": "#f6f7fb",
					"name": "سطح"
				},
				{
					"slug": "contrast",
					"color": "#14181f",
					"name": "متن"
				},
				{
					"slug": "muted",
					"color": "#5b6472",
					"name": "متن کم‌رنگ"
				},
				{
					"slug": "primary",
					"color": "#1f6feb",
					"name": "اصلی"
				},
				{
					"slug": "primary-dark",
					"color": "#1a5fce",
					"name": "اصلی تیره"
				},
				{
					"slug": "accent",
					"color": "#ff8a3d",
					"name": "تأکید"
				},
				{
					"slug": "success",
					"color": "#1f9d55",
					"name": "موفق"
				},
				{
					"slug": "border",
					"color": "#e3e6ed",
					"name": "خط"
				}
			],
			"gradients": [
				{
					"slug": "primary-accent",
					"gradient": "linear-gradient(135deg, #1f6feb 0%, #ff8a3d 100%)",
					"name": "اصلی به تأکید"
				},
				{
					"slug": "surface-fade",
					"gradient": "linear-gradient(180deg, #f6f7fb 0%, #ffffff 100%)",
					"name": "محو سطح"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"customFontSize": true,
			"fontFamilies": [
				{
					"name": "وزیرمتن",
					"slug": "vazirmatn",
					"fontFamily": "Vazirmatn, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Tahoma, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Vazirmatn",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Vazirmatn-Regular.woff2" ]
						},
						{
							"fontFamily": "Vazirmatn",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Vazirmatn-Medium.woff2" ]
						},
						{
							"fontFamily": "Vazirmatn",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Vazirmatn-Bold.woff2" ]
						}
					]
				},
				{
					"name": "سیستمی",
					"slug": "system",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "کوچک",
					"fluid": false
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "متوسط",
					"fluid": false
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "بزرگ",
					"fluid": {
						"min": "1.125rem",
						"max": "1.375rem"
					}
				},
				{
					"slug": "x-large",
					"size": "1.75rem",
					"name": "خیلی بزرگ",
					"fluid": {
						"min": "1.5rem",
						"max": "2rem"
					}
				},
				{
					"slug": "xx-large",
					"size": "2.75rem",
					"name": "تیتر",
					"fluid": {
						"min": "2rem",
						"max": "3.25rem"
					}
				}
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "20",
					"size": "0.5rem",
					"name": "۱"
				},
				{
					"slug": "30",
					"size": "1rem",
					"name": "۲"
				},
				{
					"slug": "40",
					"size": "1.5rem",
					"name": "۳"
				},
				{
					"slug": "50",
					"size": "2.5rem",
					"name": "۴"
				},
				{
					"slug": "60",
					"size": "4rem",
					"name": "۵"
				},
				{
					"slug": "70",
					"size": "6rem",
					"name": "۶"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"slug": "soft",
					"name": "نرم",
					"shadow": "0 1px 2px rgba(20, 24, 31, 0.06), 0 6px 20px rgba(20, 24, 31, 0.06)"
				},
				{
					"slug": "card",
					"name": "کارت",
					"shadow": "0 10px 30px rgba(20, 24, 31, 0.08)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|vazirmatn",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.7",
			"fontWeight": "400"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "0",
				"right": "var:preset|spacing|30",
				"bottom": "0",
				"left": "var:preset|spacing|30"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|primary-dark"
					}
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.3"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				},
				"border": {
					"radius": "0.6rem"
				},
				"spacing": {
					"padding": {
						"top": "0.7rem",
						"bottom": "0.7rem",
						"left": "1.4rem",
						"right": "1.4rem"
					}
				},
				"typography": {
					"fontWeight": "500"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|primary-dark"
					}
				},
				":focus": {
					"color": {
						"background": "var:preset|color|primary-dark"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontWeight": "700",
					"fontSize": "var:preset|font-size|large"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|contrast"
						}
					}
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"core/query-title": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"core/navigation": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"color": {
					"text": "var:preset|color|muted"
				}
			},
			"core/pullquote": {
				"border": {
					"width": "0",
					"radius": "0.75rem"
				},
				"color": {
					"background": "var:preset|color|surface"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40",
						"left": "var:preset|spacing|40",
						"right": "var:preset|spacing|40"
					}
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "page-no-title",
			"title": "برگه بدون عنوان",
			"postTypes": [ "page" ]
		},
		{
			"name": "page-full-width",
			"title": "برگه تمام‌عرض",
			"postTypes": [ "page" ]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "سربرگ",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "پابرگ",
			"area": "footer"
		}
	]
}
